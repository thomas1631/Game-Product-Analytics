*/

-- 2.1. View all matches for one specific churned user, ordered by date
SELECT * FROM matches
WHERE user_id = 8325
ORDER BY activity_date_cleaned DESC;

-- 2.2. Find the absolute last date each user played a match
SELECT 
    user_id,
    MAX(activity_date_cleaned) AS final_match_date
FROM matches
GROUP BY user_id;

-- 2.3. Filter the Matches Table
WITH user_final_day AS (
    SELECT 
        user_id,
        MAX(activity_date_cleaned) AS final_match_date
    FROM matches
    GROUP BY user_id
)
SELECT 
    m.user_id,
    m.activity_date_cleaned,
    m.result
FROM matches m
JOIN user_final_day ufd 
    ON m.user_id = ufd.user_id AND m.activity_date_cleaned = ufd.final_match_date;
    
-- 2.4. Add the Cohort and Count the Wins
WITH user_final_day AS (
    -- 1. Find the absolute last date each user played a match
    SELECT 
        user_id, 
        MAX(activity_date_cleaned) AS final_match_date
    FROM matches
    GROUP BY user_id
),
final_day_matches AS (
    -- 2. Filter the raw matches table to only include matches from that final day
    SELECT 
        m.user_id,
        m.result
    FROM matches m
    JOIN user_final_day ufd 
        ON m.user_id = ufd.user_id 
        AND m.activity_date_cleaned = ufd.final_match_date
)
-- 3. Aggregate the filtered matches by cohort and count the wins
SELECT 
    c.user_cohort,
    COUNT(f.result) AS total_final_day_matches,
    SUM(CASE WHEN f.result = 'won' THEN 1 ELSE 0 END) AS total_final_day_wins
FROM final_day_matches f
JOIN user_cohorts_view c 
    ON f.user_id = c.user_id
GROUP BY c.user_cohort;

-- 2.5: Step 1: Check the overall final day win rate to see if players are leaving due to frustration (<40% win rate) or boredom (>60% win rate).
WITH user_final_day AS (
    -- Find the last day each user played a match
    SELECT 
        user_id,
        MAX(activity_date_cleaned) AS final_match_date
    FROM matches
    GROUP BY user_id
),
final_day_matches AS (
    -- Get all match results strictly from that final day
    SELECT 
        m.user_id,
        m.result
    FROM matches m
    JOIN user_final_day ufd 
        ON m.user_id = ufd.user_id AND m.activity_date_cleaned = ufd.final_match_date
),
cohort_final_day_performance AS (
    -- Join with our cohort view
    SELECT 
        c.user_cohort,
        COUNT(f.result) AS total_final_day_matches,
        SUM(CASE WHEN f.result = 'won' THEN 1 ELSE 0 END) AS total_final_day_wins
    FROM final_day_matches f
    JOIN user_cohorts_view c ON f.user_id = c.user_id
    GROUP BY c.user_cohort
)
-- Calculate the win rate percentage
SELECT 
    user_cohort,
    total_final_day_matches,
    total_final_day_wins,
    ROUND((total_final_day_wins / total_final_day_matches) * 100, 2) AS final_day_win_rate_percentage
FROM cohort_final_day_performance;
/*Churned Users are spending over a third of their time 
(28.01% + 5.50% + 2.61% = 36.12%) playing against bots, winning nearly 
90% of the time. Conversely, Power Users play bot matches 
less than 0.05% of the time. The early-game bot allocation 
is suffocating new players with unchallenging gameplay, 
causing them to abandon the app out of boredom.
*/

-- 2.6: Step 2: Segment the final day win rate by match type to determine if the 59% average is hiding extreme imbalances.
WITH user_final_day AS (
    -- 1. Find the absolute last date each user played a match
    SELECT 
        user_id,
        MAX(activity_date_cleaned) AS final_match_date
    FROM matches
    GROUP BY user_id
),
final_day_matches AS (
    -- 2. Filter raw matches to ONLY include those final day matches
    SELECT 
        m.user_id,
        m.match_type,
        m.teams,
        m.result
    FROM matches m
    JOIN user_final_day ufd 
        ON m.user_id = ufd.user_id 
        AND m.activity_date_cleaned = ufd.final_match_date
)
-- 3. Join cohorts and calculate metrics strictly on the final day's data
SELECT 
    c.user_cohort,
    f.match_type,
    f.teams,
    COUNT(*) AS total_final_day_matches,
    
    -- Percentage of final day play
    ROUND((COUNT(*) / SUM(COUNT(*)) OVER(PARTITION BY c.user_cohort)) * 100, 2) AS percentage_of_final_day_play,
    
    -- Final day wins
    SUM(CASE WHEN f.result = 'won' THEN 1 ELSE 0 END) AS total_final_day_wins,
    
    -- Final day win rate
    ROUND((SUM(CASE WHEN f.result = 'won' THEN 1 ELSE 0 END) / COUNT(*)) * 100, 2) AS final_day_win_rate

FROM final_day_matches f
JOIN user_cohorts_view c 
    ON f.user_id = c.user_id
GROUP BY c.user_cohort, f.match_type, f.teams
ORDER BY c.user_cohort, percentage_of_final_day_play DESC;

/*
=============================================================================
3. HYPOTHESIS : THE BOT TRAP (ARTIFICIAL BOREDOM)
=============================================================================

1. The Observation
   - The previous query revealed that Churned Users have a 59% win rate on 
     the day they permanently quit. This invalidates the "Frustration" 
     hypothesis and strongly indicates "Boredom".

2. The Structural Theory (Game Design)
   - Mobile PvP games frequently use AI bots in early-game matchmaking to 
     eliminate queue times and guarantee easy first wins. 
   - If players are kept in this "Bot Pool" for too long, they recognise 
     the lack of genuine human competition, the victories feel hollow, 
     and they abandon the app.

3. The Objective & Test
   - Locate the opponent type identifier within the 'matches' schema.
   - Calculate the total volume and percentage of matches played against bots 
     for each cohort.
   - Prove whether Churned Users are disproportionately exposed to bot matches 
     compared to Power Users.
=============================================================================
*/

-- 3.1: Add user user_cohort to "matches"
SELECT 
        c.user_cohort,
        m.match_type,
        m.teams
    FROM matches m
    JOIN user_cohorts_view c ON m.user_id = c.user_id;

-- 3.2: % of cohort played
WITH user_matches AS (
    -- Join matches with our cohort view
    SELECT 
        c.user_cohort,
        m.match_type,
        m.teams
    FROM matches m
    JOIN user_cohorts_view c ON m.user_id = c.user_id
)
-- See what each cohort is actually playing
SELECT 
    user_cohort,
    match_type,
    teams,
    COUNT(*) AS total_matches_played,
    -- Using a window function to see the percentage breakdown WITHIN each cohort
    ROUND((COUNT(*) / SUM(COUNT(*)) OVER(PARTITION BY user_cohort)) * 100, 2) AS percentage_of_cohort_play
FROM user_matches
GROUP BY user_cohort, match_type, teams
ORDER BY user_cohort, percentage_of_cohort_play DESC;

-- 3.2: Add user user_cohort to "matches" plus total_wins and win rate percentage
WITH user_matches AS (
    -- 1. Join matches with our cohort view AND pull the result column
    SELECT 
        c.user_cohort,
        m.match_type,
        m.teams,
        m.result 
    FROM matches m
    JOIN user_cohorts_view c ON m.user_id = c.user_id
)
-- 2. Aggregate the volume, percentage of play, and win rate
SELECT 
    user_cohort,
    match_type,
    teams,
    COUNT(*) AS total_matches_played,
    -- Percentage of cohort play
    ROUND((COUNT(*) / SUM(COUNT(*)) OVER(PARTITION BY user_cohort)) * 100, 2) AS percentage_of_cohort_play,
    
    -- Win count
    SUM(CASE WHEN result = 'won' THEN 1 ELSE 0 END) AS total_wins,
    
    -- Win rate percentage for this specific match type
    ROUND((SUM(CASE WHEN result = 'won' THEN 1 ELSE 0 END) / COUNT(*)) * 100, 2) AS win_rate_percentage

FROM user_matches
GROUP BY user_cohort, match_type, teams
ORDER BY user_cohort, percentage_of_cohort_play DESC;

/*
