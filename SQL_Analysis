-- 1.7. Player Cohorts (The Product Foundation)
WITH user_activity AS(
	SELECT 
    user_id,
    count(distinct activity_date_cleaned) as days_active
FROM daily_activity
GROUP BY user_id
)
SELECT
user_id,
days_active,
	CASE 
		WHEN days_active > 25 Then 'Power User'
		WHEN days_active < 3 Then 'Churned User'
ELSE 'Regular User'
END AS user_chort
FROM user_activity;

-- 1.8. let's create a VIEW
CREATE OR REPLACE VIEW user_cohorts_view AS
SELECT 
    user_id,
    COUNT(DISTINCT activity_date_cleaned) AS days_active,
    CASE 
        WHEN COUNT(DISTINCT activity_date_cleaned) > 25 THEN 'Power User'
        WHEN COUNT(DISTINCT activity_date_cleaned) < 3 THEN 'Churned User'
        ELSE 'Regular User'
    END AS user_cohort
FROM daily_activity
GROUP BY user_id;

SELECT* FROM user_cohorts_view;

-- 1.9. Cohort Number and Percentage
WITH user_activity AS (
    -- 1. Calculate how many days each user was active
    SELECT 
        user_id,
        COUNT(DISTINCT activity_date_cleaned) AS days_active
    FROM daily_activity
    GROUP BY user_id
),
cohort_assignment AS (
    -- 2. Assign each user to their specific cohort
    SELECT 
        CASE 
            WHEN days_active > 25 THEN 'Power User'
            WHEN days_active < 3 THEN 'Churned User'
            ELSE 'Regular User'
        END AS user_cohort
    FROM user_activity
),
cohort_summary AS (
    -- 3. Count the total number of users in each cohort
    SELECT 
        user_cohort,
        COUNT(*) AS user_count
    FROM cohort_assignment
    GROUP BY user_cohort
)
-- 4. Calculate the percentage and format the final output
SELECT 
    user_cohort AS Cohort,
    user_count AS `User Count`,
    CONCAT(ROUND((user_count / (SELECT SUM(user_count) FROM cohort_summary)) * 100, 2), '%') AS Percentage
FROM cohort_summary
ORDER BY user_count DESC;

/*
